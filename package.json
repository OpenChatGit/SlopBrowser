{
  "name": "slopbrowser",
  "version": "0.1.4",
  "description": "A browser that blocks AI slop across the whole web - like an ad blocker against AI-generated junk.",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/build-chrome-module.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build:chrome": "node scripts/build-chrome-module.js",
    "postinstall": "node scripts/ensure-electron.js",
    "test": "node test/engine-test.js"
  },
  "keywords": [
    "browser",
    "electron",
    "ai-slop",
    "content-filter",
    "adblock"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nicol/SlopBrowser"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.43",
    "adblock-rs": "^0.12.5",
    "cross-fetch": "^4.1.0",
    "dompurify": "^3.4.12",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "highlight.js": "^11.11.1",
    "lucide": "^1.23.0",
    "marked": "^18.0.6"
  }
}
